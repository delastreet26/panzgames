# =============================================
# PANZGAMES - Variables de Entorno
# Copia este archivo como .env.local y rellena los valores
# =============================================

# --- SUPABASE (base de datos) ---
# Obtén estos valores en: https://supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- ISTHEREANYDEAL API (precios de juegos) ---
# Regístrate gratis en: https://isthereanydeal.com/dev/app/
ITAD_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- IGDB API (datos y fichas de juegos) ---
# Regístrate en: https://dev.twitch.tv → luego activa IGDB en https://api-docs.igdb.com
IGDB_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
IGDB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# --- ANTHROPIC API (genera curiosidades del juego del día con IA) ---
# Obtén tu key en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# --- CRON SECRET (protege los endpoints de automatización) ---
# Pon cualquier string largo y aleatorio, ej: genera uno en https://generate-secret.vercel.app/32
CRON_SECRET=mi_clave_secreta_muy_larga_aqui

# --- VERCEL (se rellena automáticamente al desplegar, no tocar) ---
VERCEL_URL=
